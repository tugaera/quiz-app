# ─── Supabase ───────────────────────────────────────────────
# Your Supabase project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Supabase service role key (NEVER expose to browser — server/Edge only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ────────────────────────────────────────────────────
# Full public URL of the deployed app (used for QR code generation)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app (or custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth ───────────────────────────────────────────────────
# Secret used to sign invite code tokens (min 32 chars)
INVITE_TOKEN_SECRET=replace-with-a-long-random-secret

# ─── Edge Functions ─────────────────────────────────────────
# URL of the Supabase Edge Function for the question-advance scheduler
# Development: http://localhost:54321/functions/v1/advance-question
# Production:  https://your-project-ref.supabase.co/functions/v1/advance-question
SUPABASE_EDGE_FUNCTION_URL=http://localhost:54321/functions/v1/advance-question

# ─── Optional: future infra changes ────────────────────────
# If the database is ever migrated away from Supabase-managed Postgres,
# a direct connection string can be set here (unused by default)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
